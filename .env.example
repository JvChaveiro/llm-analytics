# ============================================================
# .env.example — TEMPLATE SEGURO
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env
# ============================================================

# ─── LLM LOCAL ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── SQL SERVER ──────────────────────────────────────────────
MSSQL_SERVER=
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
# String completa (alternativa): mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+17+for+SQL+Server
MSSQL_CONNECTION_STRING=

# ─── POSTGRESQL (se usar) ────────────────────────────────────
PG_CONNECTION=postgresql://usuario:senha@localhost:5432/nome_banco

# ─── DUCKDB LOCAL ────────────────────────────────────────────
# Apenas caminho — sem credenciais
DUCKDB_PATH=./data/local.duckdb

# ─── APIS EXTERNAS (opcionais) ───────────────────────────────
# Descomente e preencha apenas se usar
# OPENAI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=

# ─── CONFIGURAÇÕES GERAIS ────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
